# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly declare text files to ensure normalization
*.py text eol=lf
*.pyi text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.csv text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.conf text eol=lf

# Shell scripts must use LF
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf

# Batch files need CRLF on Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Web files
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.xml text eol=lf

# Config files
.gitattributes text eol=lf
.gitignore text eol=lf
.editorconfig text eol=lf
Dockerfile text eol=lf
Makefile text eol=lf
*.dockerfile text eol=lf

# Jupyter notebooks (JSON-based, but special handling)
*.ipynb text eol=lf

# Binary files - don't touch these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.whl binary
*.pyc binary
*.pyo binary
*.so binary
*.dll binary
*.exe binary
